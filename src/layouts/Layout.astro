---
import "../styles/global.css";
import Header from "../components/ui/header.astro";
import Footer from "../components/ui/Footer.astro";
import Main from "../components/ui/Main.astro";
interface Props {
	title: string;
	subtitle: string;
	bgImage: string;
}
const { title, subtitle, bgImage } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={subtitle} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>Cafetería desde 1939: {title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&family=PT+Sans:wght@400;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-coffee-100">
		<Header
			bgImage={bgImage}
			subtitle={subtitle}
		 />
		 <Main title={title} class="bg-white p-20 -mt-20 mx-4 lg:mx-auto max-w-7xl relative rounded-xl shadow-2xl">
			<slot />
		 </Main>
		<Footer />
	</body>
</html>
