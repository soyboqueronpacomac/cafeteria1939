---
import { Picture } from 'astro:assets'
import type { MenuItem } from '../domain/menu.model'

interface Props {
    item: MenuItem
}
const { item } = Astro.props
---
<li class="flex flex-col md:flex-row lg:justify-between gap-5 w-full md:items-center p-5  ">
  <div class="flex-1 flex flex-col md:flex-row gap-5 items-center ">
    <div class="w-full md:w-40 lg:w-56 overflow-hidden">
        {item.image && (
            <a 
              href={item.image.url} 
              data-pswp-width={item.image.width} 
              data-pswp-height={item.image.height} 
              target="_blank"
              class="cursor-zoom-in block"
            >
              <Picture
                  src={item.image.url}
                  alt={item.title}
                  width={item.image.width}
                  height={item.image.height}
                  class="w-full h-auto object-cover rounded-lg"
                  formats={['avif', 'webp', 'jpeg']}
              />
            </a>
        )}
    </div>
    <div class="flex-1">
      <p class="text-white font-bold text-2xl text-center md:text-left">{item.title}</p>
      <p class="text-coffee-400 text-lg text-center md:text-left" set:html={item.description}></p>
    </div>
  </div>
  <p class="text-4xl font-black text-white text-center md:text-left">${item.price}</p>
</li>