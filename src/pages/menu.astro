---
import { getMenuPage } from '@/menu/infrastructure/menu.repository'
import AboutContent from '@/about/ui/AboutContent.astro'
import Layout from '@/layouts/Layout.astro'
import ProductsMenu from '@/menu/ui/ProductsMenu.astro'

const menu = await getMenuPage()

if (!menu) {
  return Astro.redirect('/404')
}
---

<Layout
  title={menu.title}
  subtitle={menu.subtitle}
  bgImage={menu.backgroundImage ?? ''}
>
  {menu.image && (
    <AboutContent
      content={menu.content}
      image={menu.image.url}
      width={menu.image.width}
      height={menu.image.height}
    />
  )}
  <ProductsMenu slot='after-main-content' />
</Layout>

<script>
  import { setupScrollReveal } from '@/shared/application/scroll-reveal.service'

  let destroy: (() => void) | undefined

  function init() {
    destroy?.()
    destroy = setupScrollReveal()
  }

  document.addEventListener('astro:page-load', init)
  init()
</script>
