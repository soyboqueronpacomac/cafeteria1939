---
import { getHomePage } from '@/home/infrastructure/home.repository'
import ListIcons from '@/home/ui/ListIcons.astro'
import Layout from '@/layouts/Layout.astro'

const home = await getHomePage()

if (!home) {
  return Astro.redirect('/404')
}
---

<Layout
  title={home.title}
  subtitle={home.subtitle}
  bgImage={home.backgroundImage}
>
  <div class="space-y-4 text-center text-coffee-800 text-lg mt-10 opacity-0 js-scroll-fade-up" set:html={home.content}></div>
  <ListIcons />
</Layout>

<script>
  import { setupScrollReveal } from '@/shared/application/scroll-reveal.service'

  let destroy: (() => void) | undefined

  function init() {
    destroy?.()
    destroy = setupScrollReveal()
  }

  document.addEventListener('astro:page-load', init)
  init()
</script>
