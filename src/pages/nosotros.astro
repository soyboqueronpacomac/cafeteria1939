---
import { getAboutPage } from '@/about/infrastructure/about.repository'
import AboutContent from '@/about/ui/AboutContent.astro'
import Layout from '@/layouts/Layout.astro'

const about = await getAboutPage()

if (!about) {
  return Astro.redirect('/404')
}
---

<Layout
  title={about.title}
  subtitle={about.subtitle}
  bgImage={about.backgroundImage}
>
  {about.image && (
    <AboutContent
      content={about.content}
      image={about.image.url}
      width={about.image.width}
      height={about.image.height}
    />
  )}
</Layout>

<script>
  import { setupScrollReveal } from '@/shared/application/scroll-reveal.service'

  let destroy: (() => void) | undefined

  function init() {
    destroy?.()
    destroy = setupScrollReveal()
  }

  document.addEventListener('astro:page-load', init)
  init()
</script>
