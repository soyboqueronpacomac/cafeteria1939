---
import { getWPPageBySlug } from '@/lib/wp';
import Layout from '@/layouts/Layout.astro';
import Aboutcontent from '@/components/nosotros/Aboutcontent.astro';

const data = await getWPPageBySlug('nosotros');

if (!data) {
  return Astro.redirect('/404');
}

const title = data.title.rendered
const subtitle = data.acf.subtitle
const bgImage = data.featured_images?.full.url!
const image = data.featured_images?.medium_large.url!
const content = data.content.rendered
const width = data.featured_images?.medium_large.width!
const height = data.featured_images?.medium_large.height!
---

<Layout
  title={title}
  subtitle={subtitle}
  bgImage={bgImage}
>
	<Aboutcontent content={content} image={image} width={width} height={height} />
</Layout>
