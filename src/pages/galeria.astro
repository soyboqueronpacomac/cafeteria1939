---
import Layout from '@/layouts/Layout.astro'
import { getGalleryPage } from '@/gallery/infrastructure/gallery.repository'
import ListGallery from '@/gallery/ui/ListGallery.astro'

const gallery = await getGalleryPage()

if (!gallery) {
  return Astro.redirect('/404')
}
---

<Layout
  title={gallery.title}
  subtitle={gallery.subtitle}
  bgImage={gallery.backgroundImage}
>
  <ListGallery images={gallery.images} />
</Layout>

