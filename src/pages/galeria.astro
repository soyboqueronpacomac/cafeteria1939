---
import { getWPPageBySlug } from '@/lib/wp';
import Layout from '@/layouts/Layout.astro';

const data = await getWPPageBySlug('galeria');

if (!data) {
  return Astro.redirect('/404');
}

const title = data.title.rendered
const subtitle = data.acf.subtitle
const bgImage = data.featured_images?.full.url!
---

<Layout
  title={title}
  subtitle={subtitle}
  bgImage={bgImage}
>
	
</Layout>
