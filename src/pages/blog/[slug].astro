---
import Layout from '@/layouts/Layout.astro'
import { getPostBySlug } from '@/blog/infrastructure/blog.repository'
import ImagePost from '@/blog/ui/ImagePost.astro'
import MetaPost from '@/blog/ui/MetaPost.astro'
import CategoryPost from '@/blog/ui/CategoryPost.astro'
export const prerender = false

const { slug } = Astro.params

if (!slug || slug === 'inicio') {
  return Astro.redirect('/')
}

if (slug === 'post') {
  return Astro.redirect('/blog')
}

const post = await getPostBySlug(slug)

if (!post) {
  return Astro.redirect('/blog')
}
---
<Layout
  title={post.title}
  subtitle={post.title}
  bgImage={post.featuredImage?.full.url}
>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start max-w-6xl mx-auto mt-10">
    <div class="opacity-0 js-scroll-fade-left">
      {post.featuredImage && (
        <div class="rounded-lg shadow-2xl overflow-hidden vintage-vignette">
          <ImagePost
            src={post.featuredImage.full.url}
            alt={post.title}
            width={post.featuredImage.mediumLarge.width}
            height={post.featuredImage.mediumLarge.height}
          />
        </div>
      )}
    </div>

    <article class="space-y-5 bg-white p-10 rounded-lg shadow-2xl opacity-0 js-scroll-fade-right">
      <MetaPost date={post.date} />
      <CategoryPost categories={post.categories} />
      <h1 class="text-4xl font-black text-coffee-900 border-b border-coffee-100 pb-4" set:html={post.title}></h1>
      <div class="text-xl text-coffee-800 space-y-4 leading-relaxed article-content" set:html={post.content}></div>
    </article>
  </div>
</Layout>

<script>
  import { setupScrollReveal } from '@/shared/application/scroll-reveal.service'

  let destroy: (() => void) | undefined

  function init() {
    destroy?.()
    destroy = setupScrollReveal()
  }

  document.addEventListener('astro:page-load', init)
  init()
</script>
