---
import Layout from '@/layouts/Layout.astro'
import ListPosts from '@/blog/ui/ListPosts.astro'
import { getAllCategorySlugs, getCategoryBySlug, getPostsByCategory } from '@/blog/infrastructure/blog.repository'

export async function getStaticPaths() {
  const slugs = await getAllCategorySlugs()
  return slugs.map(slug => ({ params: { slug } }))
}

const { slug } = Astro.params
const category = await getCategoryBySlug(slug)
const posts = await getPostsByCategory(category.id!)
---
<Layout
  title={`Categoría: ${category.name}`}
  subtitle={`Posts relacionados con la categoría ${category.name}`}
  bgImage={posts[0]?.featuredImage?.full.url}
>
  <ListPosts title={`Posts relacionados con la categoría ${category.name}`} posts={posts} />
</Layout>

<script>
  import { setupScrollReveal } from '@/shared/application/scroll-reveal.service'

  let destroy: (() => void) | undefined

  function init() {
    destroy?.()
    destroy = setupScrollReveal()
  }

  document.addEventListener('astro:page-load', init)
  init()
</script>
