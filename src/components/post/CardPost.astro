---
import type { Post } from '@/types'
import { Picture } from 'astro:assets';
import { formatDate } from '@/lib/formatter';
import MetaPost from './MetaPost.astro';
import CategoryPost from './CategoryPost.astro';
import ImagePost from './ImagePost.astro';

interface Props {
    post: Post
}
const { post } = Astro.props;

---
<article class="grid grid-cols-1 lg:grid-cols-3 gap-10 bg-white p-8 rounded-lg shadow-2xl overflow-hidden">
    <header class="lg:col-span-2 space-y-4 opacity-0 js-scroll-fade-left">
        <h3 class="text-3xl font-black text-coffee-900 hover:text-coffee-600 transition-colors">
            <a href={`/blog/${post.slug}`}>{post.title.rendered}</a>
        </h3>
        <div class="flex flex-wrap gap-4 items-center">
            <MetaPost post={post} />
            <CategoryPost post={post} />
        </div>
        <div class="text-coffee-700 text-lg line-clamp-3 leading-relaxed" set:html={post.excerpt.rendered}></div>
        <a href={`/blog/${post.slug}`} class="inline-block font-bold text-coffee-800 hover:text-coffee-600 transition-all hover:translate-x-1">
            Leer más →
        </a>
    </header>
    <div class="lg:col-span-1 opacity-0 js-scroll-fade-right">
        {
            post.featured_images && (
                <a href={`/blog/${post.slug}`} class="block overflow-hidden rounded-lg shadow-xl group vintage-vignette">
                    <div class="transition-transform duration-500 group-hover:scale-110">
                        <ImagePost post={post} />
                    </div>
                </a>
            )
        }
    </div>
</article>