---
import type { Post } from '@/types'
import { Picture } from 'astro:assets';
import { formatDate } from '@/lib/formatter';

interface Props {
    post: Post
}
const { post } = Astro.props;

---
<article class="grid grid-cols-1 lg:grid-cols-3 gap-5 bg-white p-5 rounded-lg shadow-2xl">
    <header class="lg:col-span-2 space-y-3">
        <h3 class="text-2xl font-bold text-coffee-900">
            <a href="">{post.title.rendered}</a>
        </h3>
        <p class="text-coffee-500 text-sm font-semibold">{formatDate(post.date)}</p>
        <div class="flex gap-2">
            { post.category_details?.map(({name, slug}) =>
                <a href={`/category/${slug}`} class="bg-coffee-100 text-coffee-700 text-xs px-2 py-1 rounded-full font-medium hover:bg-coffee-200 transition-colors uppercase">{name}</a>
            )}
        </div>
        <div class="text-coffee-700 line-clamp-2" set:html={post.excerpt.rendered}></div>
    </header>
    <div class="lg:col-span-1">
        {
            post.featured_images && (
                <Picture
                    src={ post.featured_images.medium_large.url }
                    alt={ post.title.rendered }
                    width={ post.featured_images.medium_large.width }
                    height={ post.featured_images.medium_large.height }
                    class="w-full h-auto object-cover rounded-lg"
                    formats={['avif', 'webp', 'jpeg']}
                />
            )
        }
    </div>
</article>