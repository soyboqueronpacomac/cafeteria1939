---
    import Logo from '@/assets/logo.svg';
    import Menu from './Menu.astro';
    interface Props {
        bgImage: string;
    }
    const { bgImage } = Astro.props;
---

<header class="min-h-72 relative pb-72">
    <div
        class="inset-0 absolute bg-center bg-cover"
        style={`background-image: url(${bgImage});`}
    ></div>
    <div class="absolute inset-0 bg-black/60" />
    <div class="relative max-w-7xl mx-auto flex flex-col items-center lg:flex-row lg:justify-between gap-4 py-8 px-4">
        <a href="/">
            <Logo class="w-72" />
        </a>
        <Menu />
    </div>
</header>