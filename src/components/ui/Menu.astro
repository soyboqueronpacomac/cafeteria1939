---
import { navigation } from "../../config/navigation";

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.endsWith('/') ? pathname : `${pathname}/`;
---

<nav>
    <ul class="flex flex-col lg:flex-row justify-center gap-6 lg:gap-8 text-center lg:text-left">
        {
            navigation.map((item) => {
                const isActive = currentPath === item.href;
                return (
                    <li>
                        <a
                            href={item.href}
                            class:list={[
                                "relative transition-colors font-medium text-lg uppercase tracking-wider block w-fit mx-auto lg:mx-0",
                                isActive 
                                    ? "text-coffee-300 pointer-events-none" 
                                    : "text-white hover:text-coffee-300 after:content-[''] after:absolute after:left-0 after:bottom-0 after:w-0 after:h-[2px] after:bg-coffee-300 after:transition-all after:duration-300 hover:after:w-full"
                            ]}
                        >
                            {item.name}
                        </a>
                    </li>
                )
            })
        }
    </ul>
</nav>
