---
    interface Props {
        heading: string;
    }   
    const { heading } = Astro.props;
---

<article class="text-center text-white space-y-3">
    <h3 class="text-coffee-400 text-2xl font-black uppercase">{heading}</h3>
    <footer class="space-y-3">
        <slot />
    </footer>
</article>